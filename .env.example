# ─────────────────────────────────────────────────────────────────────
# OPENCLAW MISSION CONTROL — Environment Variables
# Copy this file to .env.local and fill in your real values.
# Never commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────

# ── OpenClaw Gateway ─────────────────────────────────────────────────
NEXT_PUBLIC_VPS_GATEWAY_URL=https://YOUR_VPS_IP:8080
NEXT_PUBLIC_LOCAL_GATEWAY_URL=http://localhost:8080
OPENCLAW_API_KEY=your-shared-secret-key-here

# ── Telegram ──────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
TELEGRAM_CHAT_ID=your-chat-id
TELEGRAM_APPROVAL_CHANNEL=@YourChannel
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret

# ── WhatsApp (Twilio) ─────────────────────────────────────────────────
WHATSAPP_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
WHATSAPP_AUTH_TOKEN=your-twilio-auth-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_RECIPIENT=+1XXXXXXXXXX

# ── Obsidian Vault ────────────────────────────────────────────────────
# Prefer `npm run setup`, which writes this to config/openclaw.local.json.
VAULT_PATH=

# ── Google OAuth ──────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REFRESH_TOKEN=your-refresh-token
